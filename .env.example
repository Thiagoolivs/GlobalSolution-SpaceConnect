# ─── Mission Control AI — variáveis de ambiente ───
# Copie para `.env` (local) ou configure no painel do Railway (produção).

# IA generativa (obrigatória para insights/chat/narrativa)
GROQ_API_KEY=coloque_sua_chave_groq_aqui

# Banco de dados — a troca de ambiente é SÓ por esta variável.
#  • Desenvolvimento (local): deixe em branco/ausente -> usa SQLite (missao.db)
#  • Produção (Railway): use a connection string do Postgres
# DATABASE_URL=sqlite:///missao.db
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Chave de sessão Flask (defina um valor forte em produção)
SECRET_KEY=troque-isto-em-producao

# Debug do servidor de desenvolvimento (NÃO usar true em produção)
# Em produção o servidor é o gunicorn (Procfile), que ignora este flag.
FLASK_DEBUG=true
